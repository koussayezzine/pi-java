<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import java.net.URL?>

<AnchorPane prefHeight="589.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.event_match_crud.controller.SideBarController">

    <children>
        <VBox fx:id="sidebar" alignment="TOP_CENTER" spacing="15" styleClass="sidebar" prefWidth="220.0">

            <stylesheets>
                <URL value="@sidebar.css" />
            </stylesheets>

            <!-- Profil -->
            <VBox alignment="CENTER">
                <Label text="Welcome" textAlignment="CENTER" styleClass="sidebar-title">
                    <font>
                        <Font name="Berlin Sans FB Bold" size="18.0" />
                    </font>
                </Label>
                <Label fx:id="nameCurrentUser" textAlignment="CENTER" style="-fx-text-fill: white; -fx-font-size: 16px;" />
            </VBox>

            <!-- Barre de recherche -->
            <TextField promptText="Search..." style="-fx-background-radius: 15; -fx-background-color: white;" />

            <!-- Menu principal -->
            <VBox spacing="10">
                <Button onAction="#goToRevenue" text="Revenue" styleClass="sidebar-button" />
                <Button onAction="#goToNotifications" text="Notifications" styleClass="sidebar-button" />
                <Button onAction="#goToAnalytics" text="Analytics" styleClass="sidebar-button" />
                <Button onAction="#goToLikes" text="Likes" styleClass="sidebar-button" />
                <Button onAction="#goToWallets" text="Wallets" styleClass="sidebar-button" />
                <Button fx:id="editProfileButton" onAction="#openEditProfile" text="Modifier Profil" styleClass="sidebar-button" />
            </VBox>

            <!-- Logout et Dark Mode -->
            <VBox spacing="10">
                <Button onAction="#logout" text="Logout" styleClass="sidebar-button" style="-fx-background-color: #f20808; -fx-text-fill: white;" />
                <HBox alignment="CENTER" spacing="5">
                    <Label text="Dark Mode" style="-fx-text-fill: white;" />
                    <ToggleButton fx:id="darkModeToggle" onAction="#toggleDarkMode" prefHeight="26.0" prefWidth="40.0" style="-fx-background-color: #49e38f;" />
                </HBox>
            </VBox>

        </VBox>
    </children>
</AnchorPane>
